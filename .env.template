# SBS Campaign Skills — Environment Variables
# Copy this file to .env and fill in your keys

# Sending platforms — fill in whichever ones you use.
# /campaign-builder picks the right one based on the client's context CLAUDE.md.
INSTANTLY_API_KEY=
LEMLIST_API_KEY=

# Anthropic API for Claude Code skills
ANTHROPIC_API_KEY=

# Google Drive folder for /share-doc (optional)
# See Automation/share-doc/SETUP.md for how to find your folder ID
GOOGLE_DRIVE_FOLDER=

# Notion integration token for /sop-creator and /client-brief and /internal-brief.
# Required if you use those skills. Josh provides the token.
NOTION_API_KEY=

# Notion database ID for Cyprian's Task Board (used by /client-brief and /internal-brief).
# Required if you push tasks programmatically.
NOTION_CYPRIAN_TASKS_DB_ID=