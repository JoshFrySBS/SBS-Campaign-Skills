# SBS Campaign Skills — Environment Variables
# Copy this file to .env and fill in your keys

# Sending platforms — fill in whichever ones you use.
# /campaign-builder picks the right one based on the client's context CLAUDE.md.
INSTANTLY_API_KEY=
LEMLIST_API_KEY=

# Anthropic API for Claude Code skills
ANTHROPIC_API_KEY=

# Google Drive folder for /share-doc (optional)
# See Automation/share-doc/SETUP.md for how to find your folder ID
GOOGLE_DRIVE_FOLDER=

# Notion integration token for /sop-creator and /client-brief and /internal-brief.
# Required if you use those skills. Josh creates the integration in Notion and shares the
# token with Cyprian via WhatsApp. Cyprian does NOT generate his own — Notion integration
# tokens are workspace-level credentials, not per-user.
NOTION_API_KEY=

# Notion database ID for Cyprian's Task Board (used by /client-brief and /internal-brief).
# Josh provides this once after sharing the integration with the database.
NOTION_CYPRIAN_TASKS_DB_ID=

# Notion database ID for the SOP Library (used by /sop-creator push-to-notion).
# Defaults to Josh's SBS workspace if not set. Override only if pushing to a different workspace.
NOTION_SOP_LIBRARY_DB_ID=

# n8n webhook URL for /share-doc (Markdown → Google Doc conversion).
# Josh provides. Required for /share-doc, /sop-creator (step 2), /client-brief, /internal-brief.
SHARE_DOC_WEBHOOK_URL=