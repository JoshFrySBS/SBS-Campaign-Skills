# Environment variables (API keys)
.env

# Google OAuth tokens (share-doc) — personal to each user
.google-token.json

# NOTE: google-client-credentials.json is deliberately IN the repo (it's safe, not secret)
# It contains the OAuth client ID. Each user still authenticates with their own Google account.

# Working files (personal to each team member)
campaigns/drafts/**/*.md
campaigns/drafts/**/*.csv
campaigns/approved/**/*.md
campaigns/approved/**/*.csv
clay-exports/*.csv
clay-exports/*.json

# Strategy docs may contain client-specific data
# Uncomment if you want to keep these out of the repo:
# strategy/*.md

# OS and editor
.DS_Store
Thumbs.db
*.swp
*.swo

# Node
node_modules/
*.log

# Claude Code local state
.claude/projects/

# Keep folder structure
!**/.gitkeep
